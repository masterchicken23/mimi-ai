# App
PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:8080
SECRET_KEY=change-me-to-a-random-string
SESSION_SECRET=change-me-to-a-random-string

# Plaid
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox

# Outlook / Microsoft Graph (delegated permissions)
# Redirect URI (Web): http://localhost:8080/auth/outlook/callback
# Permissions: User.Read, Mail.ReadWrite, Mail.Send
MS_CLIENT_ID=your-outlook-app-client-id
MS_CLIENT_SECRET=your-outlook-client-secret-value
MS_TENANT_ID=consumers
